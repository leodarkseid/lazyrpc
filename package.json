{
  "name": "lazy-rpc",
  "version": "1.0.3",
  "main": "dist/index.js",
  "type": "module",
  "module": "dist/index.mjs",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "build": "tsup src/index.ts src/browser.ts --format cjs,esm --dts --clean --minify --shims && cp src/rpcList.min.json dist/",
    "a": "node test-npm-package/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leodarkseid/lazyrpc.git"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    "node": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "browser": {
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.js"
    },
    "default": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "json-rpc",
    "ethereum",
    "evm",
    "https",
    "websocket",
    "url",
    "blockchain",
    "polygon",
    "arbitrum",
    "optimism",
    "base",
    "bsc",
    "avalanche",
    "load-balancing",
    "failover",
    "retry-logic",
    "typescript"
  ],
  "author": {
    "email": "leodarkseid@gmail.com",
    "name": "Leo",
    "url": "https://badmuskolade.com"
  },
  "license": "MIT",
  "description": "Production-ready RPC management library with load balancing, exponential backoff, and support for 15+ EVM chains. Features TypeScript-first design, WebSocket support, and intelligent failure handling.",
  "files": [
    "/dist"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "undici": "^7.22.0"
  }
}
